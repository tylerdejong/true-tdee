# Google AdSense publisher ID. Leave blank during local development.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000

# Optional ad slot IDs. Replace these with slots from your AdSense account.
NEXT_PUBLIC_AD_SLOT_RESULTS=0000000001
NEXT_PUBLIC_AD_SLOT_MID_ARTICLE=0000000002
NEXT_PUBLIC_AD_SLOT_BOTTOM=0000000003
NEXT_PUBLIC_AD_SLOT_SIDEBAR=0000000004
NEXT_PUBLIC_AD_SLOT_STICKY_MOBILE=0000000005

# Set to true only after reviewing AdSense policy and UX impact.
NEXT_PUBLIC_ENABLE_STICKY_MOBILE_AD=false

# Google Sheets contact form integration. Do not prefix these with NEXT_PUBLIC.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CONTACT_RANGE=Contact!A:F
